        .content::-webkit-scrollbar{width:6px} .content::-webkit-scrollbar-thumb{background:rgba(255,255,255,.2);border-radius:10px}
        
        /* Navigation */
        .bottom-nav{position:fixed;left:50%;bottom:24px;transform:translateX(-50%);display:flex;gap:8px;padding:10px;border-radius:24px;background:rgba(5,6,13,.9);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.15);box-shadow:0 24px 60px rgba(0,0,0,.8), 0 0 30px rgba(245,196,107,.1);z-index:50;max-width:96vw;overflow-x:auto;}
        .nav-btn{display:flex;flex-direction:column;align-items:center;gap:4px;padding:12px 20px;border-radius:16px;color:var(--muted);font-size:12px;font-weight:700;transition:all .3s ease;white-space:nowrap;letter-spacing:0.05em;}
