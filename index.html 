        /* Cards & UI */
        .card{background:var(--glass);border:1px solid var(--border);border-radius:20px;padding:26px;backdrop-filter:blur(16px);transition:transform .3s ease, border-color .3s ease;margin-bottom:20px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);}
