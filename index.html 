        #app{position:relative;z-index:1;height:100vh;display:flex;flex-direction:column; display:none;}
        
        /* Header */
        .topbar{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--border);background:linear-gradient(180deg,rgba(10,12,26,.95),rgba(10,12,26,.7));backdrop-filter:blur(24px);position:sticky;top:0;z-index:10;}
        .brand{display:flex;align-items:center;gap:14px;}
        .brand-logo{width:46px;height:46px;border-radius:50%;background:radial-gradient(circle at 30% 30%, var(--gold-3), var(--gold-2) 60%, #6b3e0c);box-shadow:0 0 20px rgba(245,196,107,.5), inset 0 0 12px rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;color:#1a1208;font-weight:900;font-size:20px; border: 2px solid #fff3c4;}
        .brand-title{font-family:'Cinzel',serif;font-size:20px;letter-spacing:.2em;color:var(--gold-3);text-shadow:0 0 16px rgba(245,196,107,.5)}
        .brand-sub{font-size:12px;color:var(--gold);letter-spacing:.3em;text-transform:uppercase;margin-top:4px; font-weight:600;}
        
        /* Stats */
        .stats-bar{display:flex;gap:12px;flex-wrap:wrap;align-items:center; justify-content: flex-end;}
        .stat-pill{display:flex;align-items:center;gap:8px;padding:8px 16px;border-radius:12px;background:var(--glass);border:1px solid var(--border);font-size:14px;font-weight:700;backdrop-filter:blur(10px); transition: all 0.3s ease;}
