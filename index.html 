        .card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
        .card-title{font-family:'Cinzel',serif;font-size:18px;letter-spacing:.1em;color:var(--gold-3);margin-bottom:8px; font-weight: 900;}
        .card-sub{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6}
        
        .section-title{font-family:'Cinzel',serif;font-size:28px;letter-spacing:.15em;color:var(--gold-3);margin-bottom:24px;text-shadow:0 0 20px rgba(245,196,107,.3);display:flex;align-items:center;gap:12px;}
        .section-title::before{content:"";display:block;width:6px;height:24px;background:linear-gradient(180deg,var(--gold),var(--gold-2));border-radius:10px;box-shadow:0 0 16px rgba(245,196,107,.6)}
        
        /* Buttons */
        .btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;padding:14px 24px;border-radius:14px;font-weight:700;font-size:15px;background:linear-gradient(135deg,var(--gold),var(--gold-2));color:#1a1208;box-shadow:0 8px 24px rgba(245,196,107,.3);transition:all .2s ease; width: 100%; border:none; text-transform:uppercase; letter-spacing:0.05em;}
        .btn:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 12px 32px rgba(245,196,107,.5)}
        .btn:active{transform:translateY(1px) scale(0.98);}
        .btn.danger{background:linear-gradient(135deg,#ef4444,#b91c1c);color:#fff;box-shadow:0 8px 24px rgba(239,68,68,.3)}
        .btn.success{background:linear-gradient(135deg,#10b981,#047857);color:#fff;box-shadow:0 8px 24px rgba(16,185,129,.3)}
        .btn.purple{background:linear-gradient(135deg,var(--purple),#5b21b6);color:#fff;box-shadow:0 8px 24px rgba(139,92,246,.3)}
        .btn.blue{background:linear-gradient(135deg,var(--blue),#1d4ed8);color:#fff;}
        .btn.outline{background:transparent; border: 2px solid var(--gold); color: var(--gold-3); box-shadow: none;}
        .btn.outline:hover{background:rgba(245,196,107,.1);}
        
        /* Support & Multiplayer Elements */
        .premium-box { border: 2px dashed var(--gold); background: rgba(245,196,107,0.05); padding: 20px; border-radius: 16px; text-align: center; margin-top: 20px;}
        .acct-number { font-size: 32px; font-weight: 900; color: var(--gold-3); letter-spacing: 0.1em; margin: 10px 0; font-family: monospace; text-shadow: 0 0 20px rgba(245,196,107,0.4);}

.bank-name { font-size: 18px; color: #fff; font-weight: 700; background: linear-gradient(90deg, var(--gold), var(--pink)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;}
        
        .live-feed { max-height: 300px; overflow-y: auto; display:flex; flex-direction: column; gap:10px; padding-right:10px;}
        .live-feed::-webkit-scrollbar{width:4px;} .live-feed::-webkit-scrollbar-thumb{background:var(--gold); border-radius:10px;}
        .feed-item { background: rgba(0,0,0,0.5); border-left: 4px solid var(--purple); padding: 12px 16px; border-radius: 8px; display:flex; justify-content:space-between; align-items:center; animation: slideIn 0.4s ease;}
        .feed-user { font-weight: 700; color: var(--gold-3); }
        .feed-action { color: var(--text); font-size: 14px; margin-top: 4px;}
        .feed-time { font-size: 11px; color: var(--muted); }
        
        /* Table for Admin Panel */
        .admin-table { width: 100%; border-collapse: collapse; margin-top: 15px; color: #fff; font-size: 14px;}
        .admin-table th { background: rgba(255,255,255,0.1); padding: 12px; text-align: left; color: var(--gold); font-family: 'Cinzel', serif;}
        .admin-table td { padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .badge { background: rgba(16,185,129,0.2); color: #10b981; padding: 4px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;}
        .badge.offline { background: rgba(239,68,68,0.2); color: #ef4444;}
        
        /* Modals & Screens */
        .intro{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:200;background:radial-gradient(circle at center, #1a1632 0%, #05060d 80%);overflow-y:auto;padding:40px 20px}
