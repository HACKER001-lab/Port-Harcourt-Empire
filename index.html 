        .intro-logo{width:140px;height:140px;border-radius:50%;margin:0 auto 24px;background:radial-gradient(circle at 30% 30%, var(--gold-3), var(--gold-2) 50%, #6b3e0c);box-shadow:0 0 100px rgba(245,196,107,.6), inset 0 0 40px rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;color:#1a1208;font-weight:900;font-size:60px; border: 4px solid #fff3c4; animation:pulse 3s ease-in-out infinite;}
        @keyframes pulse{0%,100%{box-shadow:0 0 100px rgba(245,196,107,.6), inset 0 0 40px rgba(0,0,0,.4)}50%{box-shadow:0 0 140px rgba(245,196,107,.9), inset 0 0 40px rgba(0,0,0,.4)}}
        .intro-title{font-family:'Cinzel',serif;font-size:52px;letter-spacing:.15em;color:var(--gold-3);text-shadow:0 0 40px rgba(245,196,107,.6);margin-bottom:10px;line-height:1.1}
        .intro-sub{color:var(--muted);font-size:16px;letter-spacing:.3em;text-transform:uppercase;margin-bottom:40px; font-weight: 600;}
        
        .field{display:flex;flex-direction:column;gap:8px;text-align:left;margin-bottom:24px}
        .field label{font-size:13px;color:var(--muted);letter-spacing:.15em;text-transform:uppercase; font-weight:700;}
        .field input{padding:16px 20px;border-radius:14px;background:rgba(0,0,0,.4);border:2px solid rgba(255,255,255,0.1);color:#fff;font-size:16px;outline:none;transition:all .3s ease; box-shadow: inset 0 4px 20px rgba(0,0,0,0.5);}
        .field input:focus{border-color:var(--gold); box-shadow: 0 0 20px rgba(245,196,107,0.2), inset 0 4px 20px rgba(0,0,0,0.5);}
        
        .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);display:none;align-items:center;justify-content:center;z-index:300;backdrop-filter:blur(10px);padding:20px; opacity:0; transition: opacity 0.3s ease;}
        .modal{background:linear-gradient(180deg,#141832,#05060d);border:1px solid var(--border);border-radius:24px;padding:36px;max-width:800px;width:100%;box-shadow:0 40px 100px rgba(0,0,0,.9), 0 0 60px rgba(245,196,107,.15); transform: scale(0.9); transition: transform 0.3s ease; max-height: 90vh; overflow-y: auto;}

.modal.show { transform: scale(1); }
        .modal-title{font-family:'Cinzel',serif;font-size:26px;letter-spacing:.1em;color:var(--gold-3);margin-bottom:8px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 15px;}
        
        .toast-container{position:fixed;top:100px;right:24px;z-index:400;display:flex;flex-direction:column;gap:12px;max-width:380px}
        .toast{padding:16px 20px;border-radius:14px;background:rgba(20,24,50,.95);border:1px solid var(--border);backdrop-filter:blur(24px);font-size:14px;font-weight:600;animation:slideIn .4s cubic-bezier(0.175, 0.885, 0.32, 1.275);box-shadow:0 20px 50px rgba(0,0,0,.8);color:#fff; display:flex; align-items:center; gap:12px;}
        .toast.success{border-left: 4px solid #10b981;}
        .toast.danger{border-left: 4px solid #ef4444;}
        .toast.gold{border-left: 4px solid var(--gold);}
        @keyframes slideIn{from{opacity:0;transform:translateX(60px)}to{opacity:1;transform:none}}
        
        .admin-trigger { position: absolute; top: 20px; right: 20px; width: 40px; height: 40px; opacity: 0; cursor: pointer; z-index: 100; }
        
        .tab-content { display: none; animation: fadeIn 0.4s ease; }
        .tab-content.active { display: block; }
        .footer-credit { margin-top: 40px; font-size: 13px; color: var(--muted); letter-spacing: 0.1em; font-weight: 600;}
        .dev-name { color: var(--gold); font-weight: 900;}
    </style>
</head>
