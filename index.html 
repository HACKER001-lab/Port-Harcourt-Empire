        const state = {
            name: "Player",
            age: 18, // Starting at 18 for faster gameplay in premium version
            money: 5000,
            health: 100,
            energy: 100,
            fame: 0
        };

        // --- CORE FUNCTIONS ---
        function startGame() {
            const nameInput = document.getElementById('playerName').value.trim();
            if(!nameInput) {
                showToast('Username required to connect to server.', 'danger');
                return;
            }
            state.name = nameInput;
            document.getElementById('navName').innerText = state.name;
            document.getElementById('adminSelfName').innerText = state.name + " (You)";
            
            // Transition
            const intro = document.getElementById('intro');
            intro.style.opacity = '0';
            setTimeout(() => {
                intro.style.display = 'none';
                document.getElementById('app').style.display = 'flex';
                updateUI();
                localLog(Connected to Port Harcourt Server as ${state.name}.);
                showToast(Welcome to the Empire, ${state.name}, 'success');
            }, 500);
            
            // Start simulated multiplayer feed
            setInterval(simulateMultiplayerFeed, 8000);
        }

        function updateUI() {
            document.getElementById('statAge').innerText = state.age;
            document.getElementById('statMoney').innerText = state.money.toLocaleString();
            document.getElementById('statHealth').innerText = state.health;
            document.getElementById('statEnergy').innerText = state.energy;
            document.getElementById('statFame').innerText = state.fame;
            document.getElementById('adminSelfMoney').innerText = "₦" + state.money.toLocaleString();
        }

        function localLog(msg) {
            const feed = document.getElementById('eventFeed');
            const div = document.createElement('div');
            div.className = 'feed-item';
            div.style.borderLeftColor = 'var(--gold)';
            div.innerHTML = <div class="feed-action" style="color:var(--gold-3)">${msg}</div><div class="feed-time">Age ${state.age}</div>;
            feed.prepend(div);
        }

        function showToast(message, type = 'gold') {
            const container = document.getElementById('toasts');
            const toast = document.createElement('div');
            toast.className = toast ${type};
            
            let icon = '🔔';
            if(type === 'success') icon = '✅';
            if(type === 'danger') icon = '⚠️';
            
            toast.innerHTML = <span>${icon}</span> <span>${message}</span>;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(60px)';
                toast.style.transition = 'all 0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // --- ACTIONS ---
        function ageUp() {
            state.age++;
            state.health -= Math.floor(Math.random() * 5);
            state.energy = 100;
            localLog(Happy Birthday! You are now ${state.age} years old.);
            updateUI();
            
            // Random server event broadcast simulation
            if(Math.random() > 0.7) {
                simulateMultiplayerFeed(${state.name} just turned ${state.age}!);
            }
        }

function rest() {
            if(state.energy >= 100) return showToast("Already fully rested.", "gold");
            state.energy = 100;
            state.health = Math.min(100, state.health + 15);
            localLog("Slept in your apartment. Restored energy.");
            updateUI();
        }

        function work(type) {
            let cost = 0, earn = 0, reqAge = 0, reqFame = 0, jobName = "";
            
            if(type === 'street') { cost = 15; earn = 2500; jobName = "Street Hustle"; }
            if(type === 'tech') { cost = 35; earn = 45000; reqAge = 18; jobName = "Tech Freelance"; }
            if(type === 'oil') { cost = 60; earn = 500000; reqAge = 25; reqFame = 500; jobName = "Oil Block Exec"; }

            if(state.age < reqAge) return showToast(Must be ${reqAge}+ for this job., "danger");
            if(state.fame < reqFame) return showToast(Needs ${reqFame} Fame., "danger");
            if(state.energy < cost) return showToast("Not enough energy. Go sleep.", "danger");

            state.energy -= cost;
            state.money += earn;
            
            // Slight fame chance on work
            if(Math.random() > 0.8) {
                state.fame += 5;
                showToast("Gained +5 Fame from networking!", "success");
            }

            localLog(Completed ${jobName}. Earned ₦${earn.toLocaleString()}.);
            updateUI();
        }

        // --- NAVIGATION ---
        function switchTab(tabId, btn) {
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById(tab-${tabId}).classList.add('active');
        }

        // --- SIMULATED MULTIPLAYER LOGIC ---
        const fakeUsers = ["Boma_King", "Ada_PHC", "Timi_Wealth", "Chief_Wike_Fan", "Sabi_Boy_99"];
        const fakeActions = [
            "just bought a mansion in Peter Odili Road.",
            "was spotted at a VIP club in GRA.",
            "won a major oil contract.",
            "just sent ₦1,000,000 to the developer!",
            "lost all their money in a bad crypto trade.",
            "is trending on Port Harcourt Twitter."
        ];

        function simulateMultiplayerFeed(customMsg = null) {
            const feed = document.getElementById('multiplayerFeed');
            const div = document.createElement('div');
            div.className = 'feed-item';
            
            if(customMsg) {
                div.innerHTML = <div class="feed-user" style="color:var(--pink)">Server Alert</div><div class="feed-action">${customMsg}</div><div class="feed-time">Now</div>;
            } else {
                let user = fakeUsers[Math.floor(Math.random() * fakeUsers.length)];
                let action = fakeActions[Math.floor(Math.random() * fakeActions.length)];
                div.innerHTML = <div class="feed-user">${user}</div><div class="feed-action">${action}</div><div class="feed-time">Now</div>;
            }
            
            feed.prepend(div);
            // Keep feed trim
            if(feed.children.length > 15) feed.removeChild(feed.lastChild);
        }

        // --- HIDDEN ADMIN PANEL ---
        let clicks = 0;
        let clickTimer;
        function adminClicks() {
            clicks++;
            clearTimeout(clickTimer);
            if(clicks >= 3) {
                let pwd = prompt("AUTHORIZATION REQUIRED. ENTER MASTER PASSWORD:");
                if(pwd === "admin123@") {
                    document.getElementById('adminModal').style.display = 'flex';
                    setTimeout(() => document.getElementById('adminModalContent').classList.add('show'), 10);

document.getElementById('adminModal').style.opacity = '1';
                    showToast("Master Admin Override Accepted.", "success");
                } else if (pwd !== null) {
                    showToast("ACCESS DENIED. IP LOGGED.", "danger");
                }
                clicks = 0;
            }
            clickTimer = setTimeout(() => clicks = 0, 1000);
        }

        function closeAdmin() {
            document.getElementById('adminModalContent').classList.remove('show');
            document.getElementById('adminModal').style.opacity = '0';
            setTimeout(() => document.getElementById('adminModal').style.display = 'none', 300);
        }

        function adminAction(type) {
            if(type === 'money') {
                state.money += 50000000;
                showToast("Injected ₦50M into your account.", "success");
            }
            if(type === 'stats') {
                state.health = 999;
                state.energy = 999;
                state.fame += 10000;
                showToast("God Mode Stats Applied.", "success");
            }
            updateUI();
        }
    </script>
</body>
</html>